<!-- Example -->
<group name="local,syslog,sshd,">

  <!--
  Dec 10 01:02:02 host sshd[1234]: Failed none for root from 1.1.1.1 port 1066 ssh2
  -->
  <rule id="100001" level="5">
    <if_sid>5716</if_sid>
    <srcip>1.1.1.1</srcip>
    <description>sshd: authentication failed from IP 1.1.1.1.</description>
    <group>authentication_failed,pci_dss_10.2.4,pci_dss_10.2.5,</group>
  </rule>

</group>

<!--
  T1055.001 — Process Injection (DLL Injection)

  Fires on Sysmon Event ID 10 (ProcessAccess), which Wazuh normalizes to rule 61610.
  A process opening a handle into another process's memory space is the core
  primitive behind DLL injection, and it is loud enough to alert on directly.

  Rule 100200 is the detection. Rule 100100 is the tuning override that suppresses
  the known-benign sources that generate the bulk of the false positives in this lab.
-->
<group name="windows,sysmon,">

  <rule id="100200" level="12">
    <if_sid>61610</if_sid>
    <description>Possible process injection activity detected from "$(win.eventdata.sourceImage)" on "$(win.eventdata.targetImage)"</description>
    <mitre>
      <id>T1055.001</id>
    </mitre>
  </rule>

  <rule id="100100" level="0">
    <if_sid>100200</if_sid>
    <field name="win.eventdata.sourceImage" type="pcre2">(C:\\\\Windows\\\\system32)|chr</field>
    <description>Ignore Windows binaries and Chrome</description>
  </rule>

</group>
